    },
    "error.http": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Dienst antwortet nicht. Gleich nochmal versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weather service isn’t responding. Give it a minute."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Serwis nie odpowiada. Spróbuj za chwilę."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Får ikke svar akkurat nå. Vent litt og prøv igjen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сервис не отвечает. Подождите минутку."
          }
        }
      }
    },
