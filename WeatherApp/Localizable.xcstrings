    "weather.empty.prompt_detail": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zum Laden des Wetters hier nach unten ziehen. Stelle sicher, dass Ortungsdienste erlaubt sind."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pull down to fetch weather where you are. Make sure Location is allowed when prompted."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pociągnij widok w dół, by pobrać pogodę dla bieżącej lokalizacji. Pozwól na dostęp do lokalizacji, jeśli o to poprosisz."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dra ned for å oppdatere, og takk ja til posisjon hvis appen ber om det."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновление — потяните вниз. Разрешите доступ к местоположению, когда система спросит."
          }
        }
      }
    },
