    "error.decoding": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Daten lassen sich nicht lesen. Nach unten ziehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t read that response. Pull down to try again."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tego się nie da odczytać. Zjedź palcem w dół i spróbuj jeszcze raz."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Klarte ikke lese svaret. Dra ned."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не разобрали ответ сервера. Потяните вниз."
          }
        }
      }
    },
    "error.empty_query": {
      "extractionState": "manual",
      "localizations": {
